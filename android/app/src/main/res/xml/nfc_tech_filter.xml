<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:xliff="urn:oasis:names:tc:xliff:document:1.2">
    <tech-list>
        <!-- MIFARE Classic keyfobs (most common access control keyfobs) -->
        <tech>android.nfc.tech.MifareClassic</tech>
    </tech-list>
    <tech-list>
        <!-- MIFARE Ultralight -->
        <tech>android.nfc.tech.MifareUltralight</tech>
    </tech-list>
    <tech-list>
        <!-- ISO 14443-3A (NFC-A) — covers most cards/keyfobs -->
        <tech>android.nfc.tech.NfcA</tech>
    </tech-list>
    <tech-list>
        <!-- ISO 14443-3B (NFC-B) -->
        <tech>android.nfc.tech.NfcB</tech>
    </tech-list>
    <tech-list>
        <!-- ISO 14443-4 (IsoDep) — smart cards -->
        <tech>android.nfc.tech.IsoDep</tech>
    </tech-list>
    <tech-list>
        <!-- ISO 15693 (NFC-V) — vicinity cards -->
        <tech>android.nfc.tech.NfcV</tech>
    </tech-list>
    <tech-list>
        <!-- NFC-F (FeliCa) — Japanese transit cards -->
        <tech>android.nfc.tech.NfcF</tech>
    </tech-list>
    <tech-list>
        <!-- NDEF formatted tags -->
        <tech>android.nfc.tech.Ndef</tech>
    </tech-list>
    <tech-list>
        <!-- NDEF formatable tags -->
        <tech>android.nfc.tech.NdefFormatable</tech>
    </tech-list>
</resources>